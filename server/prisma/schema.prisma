generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Station {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  humanCount Int      @default(0)
  aiResult   String   @default("")
  updatedAt  DateTime @default(now()) @updatedAt
  trains     Train[]
}

model Train {
  id               Int      @id @default(autoincrement())
  trainCode        String   @unique
  humanCount       Int      @default(0)
  aiResult         String   @default("")
  currentStationId Int
  currentStation   Station  @relation(fields: [currentStationId], references: [id])
  updatedAt        DateTime @updatedAt
}

model Road {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  fromPoint    String
  toPoint      String
  distanceKm   Float    @default(0)
  vehicleCount Int      @default(0)
  coverage     Float    @default(0)
  status       String   @default("FREE_FLOW")
  aiResult     String   @default("")
  updatedAt    DateTime @default(now()) @updatedAt
}
